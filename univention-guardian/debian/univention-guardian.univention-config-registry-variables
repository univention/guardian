[guardian/authentication]
Description[en]=Require Keycloak OIDC bearer authentication on the Cerbos endpoint. When false (default), Cerbos is reachable on 127.0.0.1:3592 without auth.
Description[de]=Keycloak OIDC Bearer-Authentifizierung für den Cerbos-Endpunkt erforderlich. Bei false (Standard) ist Cerbos ohne Authentifizierung über 127.0.0.1:3592 erreichbar.
Type=bool
Categories=service-guardian
Default=false

[guardian/cerbos/keycloak/issuer-url]
Description[en]=Keycloak realm issuer URL used by oauth2-proxy to verify bearer tokens.
Description[de]=Keycloak Realm Issuer URL für die Bearer-Token-Verifikation durch oauth2-proxy.
Type=str
Categories=service-guardian

[guardian/cerbos/keycloak/jwks-url]
Description[en]=Keycloak realm JWKS URL used by Cerbos for in-depth JWT signature verification.
Description[de]=Keycloak Realm JWKS URL für die JWT-Signatur-Verifikation durch Cerbos.
Type=str
Categories=service-guardian

[guardian/cerbos/keycloak/client-id]
Description[en]=Keycloak OIDC client ID for the guardian-cerbos service. Set by the join script.
Description[de]=Keycloak OIDC Client-ID für den guardian-cerbos Dienst. Wird vom Join-Skript gesetzt.
Type=str
Categories=service-guardian
Default=guardian-cerbos

[guardian/cerbos/proxy/cookie-secret]
Description[en]=oauth2-proxy cookie secret (32 bytes, base64). Required by config validation; not used in bearer-only mode. Set by the join script.
Description[de]=oauth2-proxy Cookie Secret (32 Bytes, Base64). Erforderlich für Konfigurationsvalidierung; im Bearer-only-Modus nicht verwendet. Wird vom Join-Skript gesetzt.
Type=str
Categories=service-guardian
